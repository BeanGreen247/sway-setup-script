    background-color: #1a2a3a;
    color: #6a8aaa;
    border: 1px solid rgba(42,90,138,0.4);
}
#btn-cancel:hover {
    background-color: #2a3a4a;
    background-image: none;
    color: #b0c8e0;
}
entry {
    background-color: #0a1628;
    background-image: none;
    color: #dce8f5;
    border: 1px solid rgba(42,90,138,0.65);
    border-radius: 6px;
    font-family: "DejaVu Sans Mono";
    font-size: 10pt;
    padding: 6px 10px;
    box-shadow: none;
}
