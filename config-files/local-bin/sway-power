}
separator {
    background-color: rgba(42,90,138,0.35);
    min-height: 1px;
    margin-top: 16px;
    margin-bottom: 16px;
}
"""

ACTIONS = {
    'sleep':    ('systemctl', 'suspend'),
    'reboot':   ('systemctl', 'reboot'),
    'shutdown': ('systemctl', 'poweroff'),
}


class PowerWindow(Gtk.Window):
    def __init__(self):
        super().__init__()
        self.set_title("Power")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        self.connect("key-press-event", self._on_key)

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.set_margin_top(16); outer.set_margin_bottom(16)
        outer.set_margin_start(16); outer.set_margin_end(16)
        self.add(outer)

        self._card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self._card.set_name("card")
        outer.pack_start(self._card, True, True, 0)

        self._build_menu()

    # ── menu view ─────────────────────────────────────────────────────────────

    def _build_menu(self):
        self._clear_card()
        self.set_default_size(340, 0)

        title = Gtk.Label(label="Power Options")
        title.set_name("title")
        title.set_halign(Gtk.Align.CENTER)
        self._card.pack_start(title, False, False, 0)

        sep = Gtk.Separator()
        self._card.pack_start(sep, False, False, 0)

        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        btn_box.set_halign(Gtk.Align.CENTER)
        self._card.pack_start(btn_box, False, False, 0)

        for label, action, name in [
            ("  Sleep",    'sleep',    'btn-sleep'),
            ("  Reboot",   'reboot',   'btn-reboot'),
            ("  Shutdown", 'shutdown', 'btn-shutdown'),
        ]:
            btn = Gtk.Button(label=label)
            btn.set_name(name)
            btn.get_child().set_xalign(0.5)
            btn.connect("clicked", self._on_action, action)
            btn_box.pack_start(btn, False, False, 0)

        sep2 = Gtk.Separator()
        self._card.pack_start(sep2, False, False, 0)

        cancel = Gtk.Button(label="Cancel")
        cancel.set_name("btn-cancel")
        cancel.get_child().set_xalign(0.5)
        cancel.connect("clicked", lambda _: Gtk.main_quit())
        self._card.pack_start(cancel, False, False, 0)

        self.show_all()

    # ── helpers ───────────────────────────────────────────────────────────────

    def _clear_card(self):
        for child in self._card.get_children():
            self._card.remove(child)

    def _on_action(self, _btn, action):
        self._execute(action)

    def _execute(self, action):
        cmd = ACTIONS[action]
        try:
            result = subprocess.run(
                ['systemctl', cmd[1]],
                capture_output=True, text=True
            )
            if result.returncode != 0:
                err = result.stderr.strip()
                dialog = Gtk.MessageDialog(
                    parent=self, flags=0,
                    message_type=Gtk.MessageType.ERROR,
                    buttons=Gtk.ButtonsType.OK,
                    text=f"systemctl {cmd[1]} failed:\n{err[:120]}"
                )
                dialog.run()
                dialog.destroy()
        except Exception as e:
            pass

    def _on_key(self, _w, event):
        if event.keyval == Gdk.KEY_Escape:
            Gtk.main_quit()


win = PowerWindow()
win.show_all()
Gtk.main()
