#!/usr/bin/env python3
"""sway-power — Sleep / Reboot / Shutdown menu with sudo auth."""
import gi, os, sys, subprocess
os.environ.setdefault('GDK_BACKEND', 'x11')
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk

CSS = b"""
