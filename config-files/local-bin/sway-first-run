    ("gtk-3.0 / settings.ini",  f"{BASE_RAW}/gtk-3.0/settings.ini",      f"{CONFIG}/gtk-3.0/settings.ini",       False, False),
    ("gtk-3.0 / gtk.css",       f"{BASE_RAW}/gtk-3.0/gtk.css",           f"{CONFIG}/gtk-3.0/gtk.css",            False, False),
    # gsimplecal
    ("gsimplecal / config",     f"{BASE_RAW}/gsimplecal/config",          f"{CONFIG}/gsimplecal/config",          False, False),
    # local-bin tools
    ("tool / sway-welcome",     f"{BASE_RAW}/local-bin/sway-welcome",     f"{BIN}/sway-welcome",                  True,  True),
    ("tool / sway-power",       f"{BASE_RAW}/local-bin/sway-power",       f"{BIN}/sway-power",                    True,  True),
    ("tool / cal-popup",        f"{BASE_RAW}/local-bin/cal-popup",        f"{BIN}/cal-popup",                     True,  True),
    ("tool / cal-toggle",       f"{BASE_RAW}/local-bin/cal-toggle",       f"{BIN}/cal-toggle",                    True,  True),
    # dotfiles
    (".vimrc",                  f"{DOTFILES_RAW}/vim/vimrc",              f"{HOME}/.vimrc",                       False, False),
    (".bashrc",                 f"{DOTFILES_RAW}/bashrc/bashrc",          f"{HOME}/.bashrc",                      False, False),
]

# Exit silently if already run (unless --force passed)
if os.path.exists(FLAG) and '--force' not in sys.argv:
    sys.exit(0)

